# ===========================================
# アプリケーション設定
# ===========================================

# Azure Speech Service のエンドポイント URL（必須）
SPEECH_ENDPOINT=https://<your-resource-name>.cognitiveservices.azure.com/

# Azure OpenAI Service のエンドポイント URL（必須）
OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/

# Azure OpenAI のデプロイメント名（省略時: gpt-4.1-mini）
OPENAI_DEPLOYMENT=gpt-4.1-mini

# ===========================================
# 簡易認証設定（任意）
# 両方設定するとユーザー名・パスワード認証が有効になります
# ===========================================

# 認証用ユーザー名
USER_NAME=your_username

# 認証用パスワード
USER_PASSWORD=your_password

# ===========================================
# Azure インフラ設定（deploy.ps1 で使用）
# ===========================================

# デプロイ先の Azure リソースグループ名
RESOURCE_GROUP=<your-resource-group>

# Azure Container Registry の名前
CONTAINER_REGISTRY_NAME=<your-acr-name>

# Azure Container Apps Environment の名前
ENVIRONMENT_NAME=<your-container-apps-environment-name>
